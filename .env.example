# Add at least one API key for AI commit generation.
# App works without keys (uses local fallback) but results are better with APIs.

# Optional - Gemini (Google AI)
# GEMINI_API_KEY=

# Optional - Hugging Face (enables Free HF + paid models)
# HUGGING_FACE_TOKEN=

# Optional - AIML API
# AIML_API_KEY=

# Optional - OpenAI
# OPENAI_API_KEY=
